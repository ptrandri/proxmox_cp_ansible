---
all:
  children:
    app_servers:
      hosts:
        # SSH key example:
        # app-prod:
        #   ansible_host: "YOUR_VM_IP"
        #   ansible_user: "ubuntu"
        #   ansible_ssh_private_key_file: "~/.ssh/id_rsa"

        # Password example:
